# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local (settings + worktrees etc.)
.claude/

# OS / editors
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

.vercel

# clerk configuration (can include secrets)
/.clerk/

# local secret: Supabase PAT handed in for Management-API migrations (rotate after use)
/.supabase-pat

# playwright MCP browser profile
/.playwright-mcp/

# local verification artifacts — browser-check screenshots dropped at repo root
# (committed images live under public/ and app/, which these globs don't touch)
/*.png
/*.jpg
/*.jpeg

# Agent skills bundle (clerk/skills) — local tooling, not product code
.agents/
